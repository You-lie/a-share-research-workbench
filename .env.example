# Copy this file to .env and fill in only the services you use.
# 复制本文件为 .env，只填写你会使用的服务。
# Do not commit the resulting .env file.
# 生成后的 .env 含有密钥，严禁提交到 Git。

# Required for LLM analysis and MiroFish reasoning (OpenAI-compatible API).
# 深度分析与 MiroFish 推演需要兼容 OpenAI 格式的 LLM。
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Optional A-share and news data sources.
# 可选的 A 股与新闻数据源；不填时，对应功能会降级或不可用。
TUSHARE_TOKEN=
TAVILY_API_KEY=

# Optional MiroFish graph memory.
# 可选的 MiroFish 图记忆服务。
ZEP_API_KEY=

# Local StockFish server. Keep it bound to loopback for personal use.
# 本地 StockFish 服务；个人使用请保持回环地址，避免暴露到局域网或公网。
HOST=127.0.0.1
PORT=8000
DEBUG=false

# Market-data backend: mock / akshare / tushare / advanced.
# 行情数据后端：mock / akshare / tushare / advanced。
STOCK_BACKEND=advanced

# Optional: allow public SearXNG fallbacks when no news search key is configured.
# 可选：未配置新闻搜索 Key 时，是否允许公开 SearXNG 作为备用来源。
SEARXNG_PUBLIC_INSTANCES_ENABLED=false

# Real-time quote source preference.
# 实时行情来源优先级。
REALTIME_SOURCE_PRIORITY=tencent,tushare,efinance,akshare_em

# MiroFish is started automatically with StockFish when it is local.
# 本地 MiroFish 会由 StockFish 自动启动；远程地址只会复用，不会拉起子进程。
MIROFISH_HOST=localhost
MIROFISH_PORT=5001
MIROFISH_AUTO_START=true
MIROFISH_START_TIMEOUT_SECONDS=20

# MiroFish simulation defaults.
# MiroFish 推演默认参数。
OASIS_DEFAULT_MAX_ROUNDS=20
OASIS_SIMULATION_AGENT_COUNT=15

# Optional proxy used only by the Qlib data downloader.
# 可选代理，仅供 Qlib 数据下载使用。
# QLIB_DATA_PROXY=socks5://192.168.31.123:46590

# Required only when using Qlib. Replace with the Python executable in your
# dedicated Qlib Conda environment. Data, models, and runtime files default
# to project-local qlib-zh directories and can be changed in the UI.
# 仅在使用 Qlib 时需要。替换为独立 Qlib Conda 环境中的 Python 路径；
# 数据、模型和运行文件默认位于项目内，也可在页面中调整。
QLIB_PYTHON=C:\path\to\conda\envs\stock_qlib\python.exe

# Windows default: use threads to avoid multiprocessing permission errors.
# Windows 默认使用线程，避免 multiprocessing 权限错误。
JOBLIB_MULTIPROCESSING=0
